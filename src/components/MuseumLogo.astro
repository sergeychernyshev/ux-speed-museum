---
import logo from '../assets/logo.svg?raw';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['museum-logo-wrapper', className]} set:html={logo} />

<style is:global>
  .museum-logo-wrapper {
    width: 32px;
    height: 32px;
    display: inline-block;
    flex-shrink: 0;
  }

  .museum-logo-wrapper svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Ensure the animation from the SVG file works when inlined */
  #museum-logo .spinner-tr,
  #e1lPOjEeBwU3_tr {
    animation: museum-logo-rotate 10000ms linear infinite normal forwards;
  }

  @keyframes museum-logo-rotate {
    0% {
      transform: translate(35.225001px, 35.225001px) rotate(0deg);
    }
    100% {
      transform: translate(35.225001px, 35.225001px) rotate(359deg);
    }
  }

  /* Original SVG ID from file */
  @keyframes e1lPOjEeBwU3_tr__tr {
    0% {
      transform: translate(35.225001px, 35.225001px) rotate(0deg);
    }
    100% {
      transform: translate(35.225001px, 35.225001px) rotate(359deg);
    }
  }
</style>
