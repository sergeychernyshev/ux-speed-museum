---
import ExhibitLayout from '../layouts/ExhibitLayout.astro';
import { Image } from 'astro:assets';
import slowStarterImg from '../assets/slow-starter.webp';
import inputAbyssImg from '../assets/input-abyss.webp';
import layoutLeapImg from '../assets/layout-leap.webp';
import unfortunateShiftImg from '../assets/unfortunate-shift.webp';

const title = 'Welcome to the Museum';
---

<ExhibitLayout title={title} showShield={false}>
  <div class="welcome-stage">
    <h1>{title}</h1>
    <p class="intro-text">
      The UX Speed Museum is a place to experience the visceral impact of
      performance bottlenecks. Here, we don't just measure metrics; we feel
      them. Explore our exhibits to understand why speed matters.
    </p>

    <div class="cta-section">
      <h2>Gallery of Exhibits</h2>
      <div class="exhibit-grid">
        <a href="/exhibits/slow-starter/" class="exhibit-card">
          <div class="exhibit-card-header">
            <h3>The Slow Starter</h3>
          </div>
          <div class="exhibit-card-image">
            <Image
              src={slowStarterImg}
              alt="Slow Starter Exhibit"
              width={600}
              height={338}
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <div class="exhibit-card-content">
            <p>
              Experience the impact of slow start of page rendering on overall
              experience and how delays in server response or render-blocking
              resources increase user abondonment.
            </p>
          </div>
        </a>
        <a href="/exhibits/input-abyss/" class="exhibit-card">
          <div class="exhibit-card-header">
            <h3>The Input Abyss</h3>
          </div>
          <div class="exhibit-card-image">
            <Image
              src={inputAbyssImg}
              alt="Input Abyss Exhibit"
              width={600}
              height={338}
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <div class="exhibit-card-content">
            <p>
              Feel the frustration of input latency. Compare instant feedback
              against delayed responses for buttons and text inputs.
            </p>
          </div>
        </a>
        <a href="/exhibits/layout-leap/" class="exhibit-card">
          <div class="exhibit-card-header">
            <h3>The Layout Leap</h3>
          </div>
          <div class="exhibit-card-image">
            <Image
              src={layoutLeapImg}
              alt="The Layout Leap Exhibit"
              width={600}
              height={338}
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <div class="exhibit-card-content">
            <p>
              Experience the "jank" of Cumulative Layout Shift (CLS) where
              content jumps unexpectedly, causing frustration and accidental
              clicks.
            </p>
          </div>
        </a>
        <a href="/exhibits/unfortunate-shift/" class="exhibit-card">
          <div class="exhibit-card-header">
            <h3>The Unfortunate Shift</h3>
          </div>
          <div class="exhibit-card-image">
            <Image
              src={unfortunateShiftImg}
              alt="The Unfortunate Shift Exhibit"
              width={600}
              height={338}
            />
          </div>
          <div class="exhibit-card-content">
            <p>
              Feel the visceral frustration of an accidental click. Watch a
              dialog button shift away just as you're about to click it.
            </p>
          </div>
        </a>
      </div>
    </div>
  </div>

  <style>
    .welcome-stage {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 4rem 2rem;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      gap: 2rem;
    }

    h1 {
      font-size: 2.5rem;
      color: var(--accent-color);
    }

    .intro-text {
      font-size: 1.25rem;
      max-width: 800px;
      line-height: 1.6;
    }

    .cta-section {
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border-color);
      width: 100%;
    }

    .exhibit-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 300px));
      justify-content: center;
      gap: 2rem;
      margin-top: 2rem;
      width: 100%;
    }

    .exhibit-card {
      background: var(--sidebar-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      text-decoration: none;
      color: inherit;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      font-size: 0.8rem;
      transition:
        transform 0.2s,
        border-color 0.2s;
    }

    .exhibit-card:hover {
      transform: translateY(-4px);
      border-color: var(--accent-color);
    }

    .exhibit-card-header {
      padding: 1.5rem 1.5rem 0.5rem 1.5rem;
      text-align: left;
    }

    .exhibit-card-header h3 {
      margin: 0;
      color: var(--accent-color);
    }

    .exhibit-card-image {
      width: 100%;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: var(--card-bg);
      border-top: 1px solid var(--border-color);
      border-bottom: 1px solid var(--border-color);
    }

    .exhibit-card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .exhibit-card-content {
      padding: 1.5rem;
      text-align: left;
    }
  </style>
</ExhibitLayout>
